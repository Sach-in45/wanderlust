<% layout("/layouts/boilerplate.ejs") %>
<div class="row">
  <div class="col-lg-8 offset-lg-2">
    <h4 class="mb-4">Create New Listing</h4>

    <form action="/listings" method="POST" novalidate class="needs-validation mb-3" enctype="multipart/form-data">

      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" name="listing[title]" id="title"
          placeholder="Add a catchy title" class="form-control" required />
        <div class="invalid-feedback">Title is required!</div>
      </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" id="description"
          class="form-control" rows="4"
          placeholder="Describe your listing..." required></textarea>
        <div class="invalid-feedback">Description is required!</div>
      </div>

      <!-- ✅ CATEGORY FIELD ADDED -->
      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <select name="listing[category]" id="category" class="form-control" required>
          <option value="">Select Category</option>
          <option value="Trending">Trending</option>
          <option value="Lake">Lake</option>
          <option value="Mountain">Mountain</option>
          <option value="Beach">Beach</option>
          <option value="Forest">Forest</option>
          <option value="City">City</option>
          <option value="Snow">Snow</option>
          <option value="Camping">Camping</option>
          <option value="Historical">Historical</option>
          <option value="Hotels">Hotels</option>
          <option value="Food">Food</option>
        </select>
        <div class="invalid-feedback">Please select a category!</div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Upload image</label>
        <input type="file" name="listing[image]" id="image" class="form-control" required/>
        <div class="form-text">Leave blank to use a default image.</div>
      </div>

      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input type="text" name="listing[location]" id="location"
          placeholder="Mumbai, Maharashtra" class="form-control" required />
        <div class="invalid-feedback">Location is required!</div>
      </div>

      <div class="row">
        <div class="mb-3 col-md-6">
          <label for="country" class="form-label">Country</label>
          <input type="text" name="listing[country]" id="country"
            placeholder="India" class="form-control" required />
          <div class="invalid-feedback">Country is required!</div>
        </div>
        <div class="mb-3 col-md-6">
          <label for="price" class="form-label">Price per night (&#8377;)</label>
          <input type="number" name="listing[price]" id="price"
            placeholder="1200" class="form-control" required min="1" />
          <div class="invalid-feedback">Enter a valid price!</div>
        </div>
      </div>

      <div class="d-flex gap-2 mt-2">
        <button class="btn btn-primary">
          <i class="fa-solid fa-plus me-1"></i>Create Listing
        </button>
        <a href="/listings" class="btn btn-dark">Cancel</a>
      </div>

    </form>
  </div>
</div>