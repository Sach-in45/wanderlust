<% layout("/layouts/boilerplate.ejs") %>

    <div class="row mt-3">
        <div class="col-8 offset-2">

            <h3 class="mb-1">
                <%= thisListing.title %>
            </h3>
            <p class="text-muted small mb-3">
                <i class="fa-solid fa-location-dot me-1 text-danger"></i>
                <%= thisListing.location %>, <%= thisListing.country %>
            </p>

            <!-- Listing Image -->
            <img src="<%= thisListing.image.url || 'https://plus.unsplash.com/premium_photo-1771774994010-576337c0d143?w=600&auto=format&fit=crop&q=60' %>"
                class="show-img mb-4" alt="<%= thisListing.title %>" />

            <!-- Details Card -->
            <div class="show-card card mb-4">
                <div class="card-body p-4">
                    <p class="card-text mt-1 mb-3"> Owned By : <i>
                            <%= thisListing.owner.username %>
                        </i></p>
                    <p class="card-text mb-3">
                        <%= thisListing.description %>
                    </p>
                    <p class="mb-3">
                        <span class="show-price">&#8377; <%= thisListing.price.toLocaleString("en-IN") %></span>
                        <span class="text-muted">/ night</span>
                    </p>
                    <% if (currentUser && currentUser._id.equals(thisListing.owner._id) ){ %>
                        <div class="btns">
                            <a href="/listings/<%= thisListing._id %>/edit" class="btn edit-btn">
                                <i class="fa-solid fa-pen-to-square me-1"></i>Edit
                            </a>
                            <form action="/listings/<%= thisListing._id %>?_method=DELETE" method="POST">
                                <button class="btn btn-outline-danger del">
                                    <i class="fa-solid fa-trash me-1"></i>Delete
                                </button>
                            </form>
                        </div>
                        <% } %>

                </div>
            </div>

            <hr />

            <!-- Leave a Review -->
            <% if(currentUser) { %>
                <div class="review-form-card card mb-4">
                    <div class="card-body">
                        <h5 class="text-center">Leave a Review</h5>
                        <form action="/listings/<%= thisListing._id %>/reviews" method="POST" novalidate
                            class="needs-validation">
                            <div class="mb-3">
                                <fieldset class="starability-slot">
                                    <h5>Rating:</h5>
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" checked/>
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>
                            <div class="mb-3">
                                <label for="comment" class="form-label">Comment</label>
                                <textarea name="review[comment]" id="comment" rows="3" class="form-control"
                                    placeholder="Share your experience..." required></textarea>
                                <div class="invalid-feedback">Please write a comment!</div>
                            </div>
                            <button class="btn add-btn">
                                <i class="fa-solid fa-paper-plane me-1"></i>Submit Review
                            </button>
                        </form>
                    </div>
                </div>
                <% } %>

                    <!-- All Reviews -->
                    <% if (thisListing.reviews.length> 0) { %>
                        <h5 class="mb-3">
                            <i class="fa-solid fa-star me-1" style="color:#fe424d;"></i>
                            All Reviews
                            <span class="text-muted small fw-normal">(<%= thisListing.reviews.length %>)</span>
                        </h5>
                        <div class="row g-3 mb-5">
                            <% for(let review of thisListing.reviews) { %>
                                <div class="col-md-6">
                                    <div class="review-card card h-100">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="fw-bold">
                                                    <i class="fa-solid fa-circle-user me-1 text-secondary"></i>
                                                    <%= review.author.username %>
                                                </span>
                                                <span class="review-badge">
                                                    &#9733; <%= review.rating %> / 5
                                                </span>
                                            </div>
                                            <p class="card-text text-muted mb-3">
                                                <%= review.comment %>
                                            </p>
                                            <% if(currentUser && review.author.equals(currentUser._id)) { %>
                                                <form method="POST"
                                                    action="/listings/<%= thisListing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                                    <button class="btn btn-sm btn-outline-danger del rev-del">
                                                        <i class="fa-solid fa-trash me-1"></i>Delete
                                                    </button>
                                                </form>
                                                <% } %>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                        </div>
                        <% } else { %>
                            <p class="text-muted mb-5">No reviews yet. Be the first to review!</p>
                            <% } %>

                            <hr>
                            <h5>Where you will be</h5>
                            <div id="map" style="height: 20rem; border-radius: 5%; margin-bottom: 5%; margin-top: 5%;"></div>
        </div>

        
    </div>
<script>
  window.coordinates = <%- JSON.stringify(thisListing.geometry.coordinates) %>;
  window.listingTitle = "<%= thisListing.title %>";
</script>
